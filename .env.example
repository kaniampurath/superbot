testnet_key=
testnet_secret=

MYSQL_HOST=mariadb
MYSQL_PORT=3306
MYSQL_DATABASE=horizon_lab
MYSQL_USER=horizon_user
MYSQL_PASSWORD=horizon_password
MYSQL_ROOT_PASSWORD=root_password

REDIS_HOST=redis
REDIS_PORT=6379
UI_HOST_PORT=8501

RUN_MODE=ui
ENABLE_REAL_TESTNET_ORDERS=true
PAPER_TRADING=true
MARKET_DATA_SOURCE=TESTNET_WS
BINANCE_REST_BASE_URL=https://testnet.binance.vision
BINANCE_WS_BASE_URL=wss://stream.testnet.binance.vision:9443
MARKET_DATA_INTERVALS=1m,5m,15m
MARKET_DATA_HISTORY_LIMIT=500
MARKET_DATA_REST_BACKFILL_SECONDS=900
MARKET_DATA_WS_STALE_SECONDS=90
MARKET_DATA_WS_RECONNECT_SECONDS=10
MARKET_DATA_TRUST_ENV_PROXY=false
BINANCE_VERIFY_TLS=true
SYSTEM_STAGE=training
TRAINING_AUTO_APPROVE_PAPER=true
AUTO_APPROVE_ORDER_MODE=PAPER
TRAINING_AUTO_APPROVE_MIN_ML_CONFIDENCE=0.45
TRAINING_AUTO_APPROVE_MAX_POSITION_USDT=50

SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
KLINE_INTERVAL=1m
STRATEGY_INTERVAL=15m
MEAN_REVERSION_Z=2.1
MEAN_REVERSION_HOLD_BARS=8
MEAN_REVERSION_RSI_BUY=35
MEAN_REVERSION_RSI_SELL=65
MEAN_REVERSION_MIN_VOLUME_Z=-0.5
MEAN_REVERSION_TAKER_FILTER=true
MEAN_REVERSION_RESEARCH_ONLY=true
DEPLOY_SYMBOL_WHITELIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
HIGHER_TIMEFRAME_INTERVAL=4h
MAX_MEAN_REVERSION_ADX=35
VOLATILITY_FALLING_RATIO=0.95
EXPECTED_MOVE_COST_MULTIPLE=2.0
ORDERBOOK_CONFIRMATION_MIN_OBI=-0.10
ORDERBOOK_CONFIRMATION_MAX_OBI=0.10
ROLLING_VALIDATION_TRADES=30
VALIDATION_WORKER_SECONDS=900
VALIDATION_BACKTEST_BARS=360
VALIDATION_HISTORY_DAYS=14
VALIDATION_STORE_PATHS=false
TRAINING_AUTO_REQUIRES_VALIDATION=true
ML_ENABLED=true
ML_CONFIDENCE_GATE_ENABLED=true
MIN_ML_CONFIDENCE=0.50
ML_TRAINING_BARS=1000
ML_RETRAIN_SECONDS=3600
ML_MIN_TRAINING_ROWS=100
ML_MIN_ACCURACY=0.52
ML_MIN_PRECISION=0.40
ML_MIN_RECALL=0.03
ML_PROMOTE_ONLY_IF_BETTER=true
ML_BALANCE_CLASSES=true
ML_CANDIDATE_QUALITY_WEIGHT=1.5
ML_DRIFT_GATE_ENABLED=true
ML_DRIFT_WARNING_THRESHOLD=1.0
ML_DRIFT_BLOCK_THRESHOLD=2.0
MIN_VALIDATION_PROFIT_FACTOR=1.2
MIN_VALIDATION_EXPECTANCY_BPS=5
MAX_VALIDATION_DRAWDOWN_PCT=8
STARTING_EQUITY=100000
MAX_KELLY_FRACTION=0.05
MAX_POSITION_USDT=1000
MAX_DAILY_LOSS_PCT=2
MAX_PORTFOLIO_DD_PCT=5
MAX_TRADES_PER_DAY=20
FEE_BPS=10
SLIPPAGE_BPS=5
